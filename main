local autoChat = false
local chatMsg = "ProHub V12 Premium is the best!"
createInput("Auto Chat Text", chatMsg, function(txt) chatMsg = txt end)
task.spawn(function()
    while task.wait(3) do
        if autoChat then
            local TextChatService = game:GetService("TextChatService")
            if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                local tc = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
                if tc then tc:SendAsync(chatMsg) end
            else
                local ReplicatedStorage = game:GetService("ReplicatedStorage")
                if ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") then
                    ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(chatMsg, "All")
                end
            end
        end
    end
end)
createToggle("Auto Chat Spam", function(state) autoChat = state end)

createButton("FPS Boost", function()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        elseif v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
        end
    end
    Lighting.GlobalShadows = false
end)

createButton("Teleport to Random Player", function()
    local targets = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= p and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(targets, v)
        end
    end
    if #targets > 0 and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
        local target = targets[math.random(1, #targets)]
        p.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
    end
end)

createButton("Give BTools", function()
    local tool1 = Instance.new("HopperBin", p.Backpack)
    tool1.BinType = Enum.BinType.Clone
    local tool2 = Instance.new("HopperBin", p.Backpack)
    tool2.BinType = Enum.BinType.Hammer
    local tool3 = Instance.new("HopperBin", p.Backpack)
    tool3.BinType = Enum.BinType.Grab
end)

createToggle("Full Bright", function(state)
    if state then 
        loadstring(game:HttpGet("https://raw.githubusercontent.com/MinhLuaStudio/code_hack/refs/heads/main/brightness"))() 
    end
end)

createButton("Server Hop", function()
    local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
    for _, server in pairs(servers.data) do
        if server.playing < server.maxPlayers and server.id ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, p)
            break
        end
    end
end)

createButton("Rejoin Server", function()
    TeleportService:Teleport(game.PlaceId, p)
end)

createInput("Time of Day", 12, function(txt)
    Lighting.ClockTime = tonumber(txt) or 12
end)
