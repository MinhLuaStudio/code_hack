local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Lighting = game:GetService("Lighting")
local VirtualUser = game:GetService("VirtualUser")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")

local p = Players.LocalPlayer
local cam = workspace.CurrentCamera
local mouse = p:GetMouse()

local sg = Instance.new("ScreenGui")
sg.Name = "ProHubUI_V12_Premium"
sg.ResetOnSpawn = false
sg.IgnoreGuiInset = true

local success, _ = pcall(function() sg.Parent = CoreGui end)
if not success then sg.Parent = p:WaitForChild("PlayerGui") end

local mainColor = Color3.fromRGB(0, 210, 255)
local secColor = Color3.fromRGB(140, 0, 255)
local darkBg = Color3.fromRGB(15, 15, 20)
local lightBg = Color3.fromRGB(28, 28, 35)

local fb = Instance.new("TextButton")
fb.Size = UDim2.new(0, 70, 0, 70)
fb.Position = UDim2.new(0, 20, 0.5, -35)
fb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
fb.Text = "V12"
fb.TextColor3 = Color3.fromRGB(255, 255, 255)
fb.TextSize = 30
fb.Font = Enum.Font.GothamBlack
fb.Parent = sg

local fbGrad = Instance.new("UIGradient", fb)
fbGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, secColor), ColorSequenceKeypoint.new(1, mainColor)})
fbGrad.Rotation = 45

Instance.new("UICorner", fb).CornerRadius = UDim.new(1, 0)
local fbStroke = Instance.new("UIStroke", fb)
fbStroke.Color = Color3.fromRGB(255, 255, 255)
fbStroke.Thickness = 2.5
fbStroke.Transparency = 0.2

local drag, dragStart, startPos
fb.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        drag = true
        dragStart = i.Position
        startPos = fb.Position
        i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then drag = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local delta = i.Position - dragStart
        TweenService:Create(fb, TweenInfo.new(0.08, Enum.EasingStyle.Sine), {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}):Play()
    end
end)

local mf = Instance.new("Frame")
mf.Size = UDim2.new(0, 500, 0, 0)
mf.Position = UDim2.new(0.5, -250, 0.5, -200)
mf.BackgroundColor3 = darkBg
mf.Visible = false
mf.ClipsDescendants = true
mf.Parent = sg

Instance.new("UICorner", mf).CornerRadius = UDim.new(0, 16)
local mfStroke = Instance.new("UIStroke", mf)
mfStroke.Color = Color3.fromRGB(255, 255, 255)
mfStroke.Thickness = 2
local mfStrokeGrad = Instance.new("UIGradient", mfStroke)
mfStrokeGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, mainColor), ColorSequenceKeypoint.new(1, secColor)})

fb.MouseButton1Click:Connect(function() 
    mf.Visible = true
    if mf.Size.Y.Offset == 0 then
        TweenService:Create(mf, TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {Size = UDim2.new(0, 500, 0, 400)}):Play()
    else
        local closeTween = TweenService:Create(mf, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In), {Size = UDim2.new(0, 500, 0, 0)})
        closeTween:Play()
        closeTween.Completed:Connect(function()
            if mf.Size.Y.Offset == 0 then mf.Visible = false end
        end)
    end
end)

local header = Instance.new("Frame", mf)
header.Size = UDim2.new(1, 0, 0, 60)
header.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
header.BorderSizePixel = 0
local headGrad = Instance.new("UIGradient", header)
