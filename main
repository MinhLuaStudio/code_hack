local tracers = false
RunService.RenderStepped:Connect(function()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= p and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            if tracers then
                if not hrp:FindFirstChild("V12_Tracer") then
                    local att0 = Instance.new("Attachment", p.Character and p.Character:FindFirstChild("HumanoidRootPart") or workspace.Terrain)
                    local att1 = Instance.new("Attachment", hrp)
                    local beam = Instance.new("Beam", hrp)
                    beam.Name = "V12_Tracer"
                    beam.Attachment0 = att0
                    beam.Attachment1 = att1
                    beam.Color = ColorSequence.new(mainColor)
                    beam.FaceCamera = true
                    beam.Width0 = 0.1
                    beam.Width1 = 0.1
                else
                    local beam = hrp:FindFirstChild("V12_Tracer")
                    if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        beam.Attachment0.Parent = p.Character.HumanoidRootPart
                    end
                end
            else
                if hrp:FindFirstChild("V12_Tracer") then
                    hrp.V12_Tracer.Attachment0:Destroy()
                    hrp.V12_Tracer.Attachment1:Destroy()
                    hrp.V12_Tracer:Destroy()
                end
            end
        end
    end
end)
createToggle("ESP Tracers (V12)", function(state) tracers = state end)

