local xray = false
createToggle("X-Ray", function(state)
    xray = state
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") and v.Name ~= "HumanoidRootPart" then
            if xray then
                if not v:FindFirstChild("V12_OriginalTransparency") then
                    local numVal = Instance.new("NumberValue", v)
                    numVal.Name = "V12_OriginalTransparency"
                    numVal.Value = v.Transparency
                end
                v.Transparency = 0.75
            else
                if v:FindFirstChild("V12_OriginalTransparency") then
                    v.Transparency = v.V12_OriginalTransparency.Value
                    v.V12_OriginalTransparency:Destroy()
                end
            end
        end
    end
end)

